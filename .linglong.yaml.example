# Linglong 配置文件示例
# 复制为 .linglong.yaml 并按需修改：
#   cp .linglong.yaml.example .linglong.yaml
#
# 搜索路径：./.linglong.yaml → ~/.linglong/config.yaml
# 优先级：.linglong.yaml > 环境变量(LL_*) > 默认值

# ── 全局 ────────────────────────────────────────────
debug: false                          # 调试模式
log_level: INFO                       # 日志级别
data_dir: ~/linglong/data             # 运行时数据目录

# ── 知识库 ──────────────────────────────────────────
knowledge:
  wiki_path: ~/linglong/wiki          # Wiki Markdown 存储路径
  db_path: ~/linglong/db/knowledge.db # SQLite 数据库路径
  vector_enabled: true                # 启用向量搜索
  vector_dimensions: 768              # 嵌入维度
  watch_enabled: true                 # 监听文件系统变更
  embedding_url: http://localhost:7997   # 嵌入服务地址
  embedding_model: nomic-embed-text-v1.5   # 嵌入模型名
  embedding_api_key: null             # 嵌入服务 API Key（可选）
  generate_embeddings: true           # 创建/更新时自动生成嵌入

  # 审核引擎
  review_high_confidence_threshold: 0.9
  review_low_confidence_threshold: 0.6
  review_min_content_length: 50
  review_trusted_sources: [openclaw, claude-code, codex]
  review_sensitive_categories: [personal, financial, health, password, secret]

  # 同步
  sync_confidence: 0.95
  openclaw_wiki_path: null            # OpenClaw wiki 路径
  claude_memory_path: null            # Claude Code memory 路径
  codex_path: null                    # Codex CLI 数据路径

# ── 信息采集 ────────────────────────────────────────
ingest:
  rss_sources: []                     # RSS 源列表（通常通过 packages 管理）
  fetch_interval_minutes: 30          # 抓取间隔（分钟）
  max_items_per_source: 50            # 每源最大条目数
  package_paths:                      # 源包 YAML 文件目录
    - ~/linglong/data/packages
  verification_enabled: true          # 启用真实性验证
  verification_pass_threshold: 0.6    # 验证通过阈值

  # 验证层权重（总和 = 1.0）
  verification_weights:
    cross_reference: 0.25
    numeric_sanity: 0.2
    time_validity: 0.2
    source_authority: 0.2
    common_sense: 0.15

  # 超时（秒）
  rss_timeout: 30.0
  web_fetch_timeout: 10.0
  api_timeout: 10.0

  # 各来源默认置信度
  default_confidence:
    rss: 0.7
    web_fetch: 0.65
    api: 0.75
    sync: 0.95

# ── 内容生产 ────────────────────────────────────────
composer:
  # LLM 设置
  llm_provider: openai
  llm_model: gpt-4
  llm_api_key: null                   # API Key（也可用环境变量 LL_COMPOSER_LLM_API_KEY）
  llm_base_url: null                  # 自定义 API 地址
  llm_temperature: 0.7
  llm_max_tokens: 4096

  # 提炼器
  distiller_use_llm: false            # true = LLM 智能提炼，false = 规则聚合
  distiller_theme_threshold: 0.7
  distiller_max_themes: 5

  # 文本资产
  assets_excerpt_length: 200
  assets_cover_enabled: false

  # 模板与草稿
  template_name: blog
  drafts_dir: ~/linglong/data/drafts

  # 自动发布
  auto_publish: false
  default_publisher: hexo

  # 图片资产
  image_assets:
    enabled: true
    specs:
      background:                     # 博客背景图
        min_width: 1920
        min_height: 1080
        quality: 90
        output_dir: ~/linglong/images/backgrounds
        variants:                     # 响应式图片尺寸
          thumb: 400
          medium: 800
          large: 1200
      article_image:                  # 文章配图
        min_width: 800
        min_height: 600
        quality: 85
        output_dir: ~/linglong/images/articles
        variants:                     # 响应式图片尺寸
          thumb: 400
          medium: 800
          large: 1200
    sources:
      - name: tuchong
        url_file: ~/Downloads/resource.txt
        default_usage: both           # background | article_image | both
        resolve_via: playwright       # direct | playwright
        headless: true
        delay_range: [3, 8]           # 页面访问随机间隔（秒）
        max_count: 50
    selection:
      strategy: random
      dedup_days: 30                  # 去重窗口（天）

# ── 分发 ────────────────────────────────────────────
dispatch:
  enabled: true
  default_publisher: hexo
  hexo_site_url: https://www.linglong.wiki
  hexo_deploy_command: null           # 自定义 SSH 部署命令
  publishers:
    - name: hexo
      type: hexo
      enabled: true
      config:
        hexo_path: ~/blog
        use_git_workflow: true
        git_remote: origin
        git_branch: master
        site_url: https://www.linglong.wiki
    - name: local
      type: local
      enabled: false
      config:
        output_dir: ~/Downloads
        overwrite: false

  # 阿里云 OSS 图片 CDN（可选）
  # 开启后图片会上传到 OSS，文章中的本地路径替换为 CDN URL
  oss:
    enabled: false
    bucket_name: linglong-blog         # OSS Bucket 名称
    endpoint: oss-cn-hangzhou.aliyuncs.com  # OSS Endpoint
    cdn_domain: img.linglong.wiki      # CDN 加速域名
    access_key_id: ""                  # 建议用环境变量 LL_OSS_ACCESS_KEY_ID
    access_key_secret: ""              # 建议用环境变量 LL_OSS_ACCESS_KEY_SECRET
    prefix: images/                    # OSS 对象前缀
